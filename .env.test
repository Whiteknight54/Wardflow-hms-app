# Test Environment Configuration
# Isolated from production environment

# Database (separate port 5433 to avoid conflict)
DATABASE_URL=postgresql://admin:password123@localhost:5433/wardflow
DB_HOST=postgres
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=password123
DB_NAME=wardflow

# API Server
API_PORT=8001
API_HOST=0.0.0.0

# JWT
JWT_SECRET=test-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=120

# CORS
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,null

# pgAdmin (optional, for database inspection)
PGADMIN_DEFAULT_EMAIL=admin@wardflow.test
PGADMIN_DEFAULT_PASSWORD=admin123
PGADMIN_PORT=5051
