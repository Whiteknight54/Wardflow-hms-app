# Version control
.git
.gitignore

# Environment files - never bake secrets into the image
.env
.env.*
backend/.env

# Python cache
__pycache__
*.pyc
*.pyo
*.pyd
.Python
*.egg-info
dist/
build/
.eggs/

# OS artefacts
.DS_Store
Thumbs.db

# Editor / IDE
.vscode
.idea
*.swp
*.swo

# Test artefacts
.pytest_cache
.coverage
htmlcov/
*.log

# Docker artefacts (avoid recursive copies)
.dockerignore
