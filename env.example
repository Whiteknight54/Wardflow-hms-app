# WardFlow Backend — Environment Configuration
# Copy this file to backend/.env and fill in your values.
# docker-compose.yml loads backend/.env into the API container.
# backend/.env is gitignored and must never be committed.

# ── Database ──────────────────────────────────────────────────────────────────
# When running with docker compose this is overridden to use the service name.
# For local dev outside Docker, point at localhost:5433 (the exposed port).
DATABASE_URL=postgresql://admin:password123@localhost:5433/wardflow

# ── JWT ───────────────────────────────────────────────────────────────────────
# CHANGE THIS before any shared or production deployment.
JWT_SECRET=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=120

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the API.
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,null

# ── SMTP / Email ──────────────────────────────────────────────────────────────
# Used for OTP delivery and password-reset emails.
# Leave SMTP_HOST blank to disable email (OTP_DEV_FALLBACK will apply).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
# Generate a Gmail App Password at https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your-app-password-here
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_USE_TLS=true

# ── OTP / MFA ─────────────────────────────────────────────────────────────────
OTP_EXPIRES_MINUTES=10
OTP_RESEND_MIN_SECONDS=30
# Keep false when using real SMTP. Set true only for local fallback testing.
OTP_DEV_FALLBACK=false
OTP_ALWAYS_REQUIRED=false

# ── Password Reset ────────────────────────────────────────────────────────────
RESET_TOKEN_EXPIRES_MINUTES=30
RESET_REQUEST_MIN_SECONDS=60

# ── Bootstrap Admin Users ─────────────────────────────────────────────────────
# On API startup, any missing emails here are auto-created as System Admin users.
# Existing users are never overwritten.
BOOTSTRAP_ADMIN_EMAILS=admin@wardflow.com,wardflowhms@gmail.com
BOOTSTRAP_ADMIN_PASSWORD=password123
